# Model settings
# TRANSCRIBE_MODEL_REPO=gn64/cohere-transcribe-onnx-int8
# TRANSCRIBE_MODEL_DIR=models

# Server settings
# TRANSCRIBE_HOST=127.0.0.1
# TRANSCRIBE_PORT=8000
# TRANSCRIBE_WORKERS=2
# TRANSCRIBE_REQUEST_TIMEOUT=120
# TRANSCRIBE_MAX_REQUEST_SIZE_MB=100

# Batch settings
# TRANSCRIBE_MAX_BATCH_SIZE=10
# TRANSCRIBE_MAX_AUDIO_DURATION_SEC=600

# Security settings
# TRANSCRIBE_ALLOWED_AUDIO_DIR=/path/to/allowed/dir
# TRANSCRIBE_API_KEYS=key1,key2
# TRANSCRIBE_ENABLE_CORS=true
# TRANSCRIBE_CORS_ORIGINS=*

# Feature flags
# TRANSCRIBE_ENABLE_DML=true
# TRANSCRIBE_ENABLE_METRICS=true
# TRANSCRIBE_ENABLE_RATE_LIMIT=true
TRANSCRIBE_ENABLE_DIARIZATION=true

# HuggingFace Token (Required for pyannote speaker diarization)
TRANSCRIBE_HF_TOKEN=your_huggingface_token_here

# Cache settings
# TRANSCRIBE_KV_CACHE_POOL_SIZE=4

# Logging
# LOG_JSON=true
